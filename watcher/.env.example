# receipt_watcher 环境配置模板
# 使用前先把本文件和 install.sh 放在同一目录，并复制：cp .env.example .env
# 修改 .env 后执行：docker restart mpay-receipt-watcher

TZ=Asia/Shanghai

# Redis 控制库：Webman 写账号任务、订单快照和运行锁的库。
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Webman redis-queue 队列库，必须和后端 QUEUE_DATABASE 一致。
QUEUE_DATABASE=1

# 流水投递队列名，必须和 Webman 队列任务一致。
RECEIPT_WATCHER_QUEUE=receipt_flow_notify

# 生产固定使用 stream，多 worker、多容器共同领取账号任务。
RECEIPT_WATCHER_DISPATCH_MODE=stream

# 单容器 worker 数，建议从 4 开始。
RECEIPT_WATCHER_WORKER_PROCESSES=4

# 账号任务租约秒数。
RECEIPT_WATCHER_TASK_LEASE_SECONDS=180

# Stream 阻塞等待时间，单位毫秒。
RECEIPT_WATCHER_STREAM_BLOCK_MS=2000

# 兼容旧 poll 模式和异常等待节奏。
RECEIPT_WATCHER_POLL_SECONDS=1
RECEIPT_WATCHER_ACCOUNT_LIMIT=10

# 单 worker 内并发保持 1，总并发靠 worker 数扩展。
RECEIPT_WATCHER_CONCURRENCY=1

# 空闲日志间隔，单位秒。
RECEIPT_WATCHER_IDLE_LOG_SECONDS=30

# Docker 线上必须无头运行。
RECEIPT_WATCHER_HEADLESS=1

# 容器内路径，不要改成宿主机路径。宿主机持久化目录就是 install.sh 所在目录。
RECEIPT_WATCHER_STORAGE_DIR=/app/var/storage

# 正式授权版镜像会强制校验授权。授权码在 Webman 管理后台填写。
RECEIPT_WATCHER_LICENSE_ENFORCED=1
RECEIPT_WATCHER_LICENSE_PUBLIC_KEY_FILE=
RECEIPT_WATCHER_LICENSE_PUBLIC_KEY=

# 图鉴验证码识别。启用星驿付、天阙、易生、滑块类平台时通常需要填写。
TTSHITU_USERNAME=
TTSHITU_PASSWORD=
TTSHITU_TYPE_ID=3
